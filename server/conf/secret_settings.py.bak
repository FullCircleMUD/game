"""
This file is meant for when you want to share your game dir with
others but don't want to share all details of your specific game
or local server setup. The settings in this file will override those
in settings.py and is in .gitignore by default.

A good guideline when sharing your game dir is that you want your
game to run correctly also without this file and only use this
to override your public, shared settings.

"""

# The secret key is randomly seeded upon creation. It is used to sign
# Django's cookies and should not be publicly known. It should also
# generally not be changed once people have registered with the game
# since it will invalidate their existing sessions.
SECRET_KEY = ''

XAMAN_API_KEY = ""
XAMAN_API_SECRET = ""

# USED ON ALL ACCOUNTS CREATED BY A WALLET
DEFAULT_ACCOUNT_PASSWORD = ""

# OPEN ROUTER API KEY
LLM_API_KEY = ""

#OPEN API KEY
LLM_EMBEDDING_API_KEY = ""

#USED TO ALLOW AUTO CREATED SUPERUSER TO LOG INTO GAME 
#WITHOUT A WALLET LINKED TO ACCOUNT AS SUPERUSER IS CREATED 
INITIALLY AT MIGRATION WITHOUT AN ASSOCIATED WALLET ADDRESS

SUPERUSER_ACCOUNT_NAME = ""

# ADDRESS USED ON THE SUPERUSER ACCOUNT SET ON INITIAL LOGIN
SUPERUSER_XRPL_WALLET_ADDRESS = "" # dev wallet (superuser default)

# ── Mainnet XRPL ──
XRPL_NETWORK_URL = ""
XRPL_VAULT_ADDRESS = ""
XRPL_ISSUER_ADDRESS = ""
# Signer Key A only — NOT the vault master seed
XRPL_VAULT_WALLET_SEED = ""

# ── Multisig Co-Signing (mainnet) ──
XRPL_MULTISIG_ENABLED = True
XRPL_COSIGNER_URL = ""
XRPL_COSIGNER_API_KEY = ""

BOT_ACCOUNT_USERNAMES = []

BOT_WALLET_ADDRESSES = {}

BOT_PASSWORDS = {}
